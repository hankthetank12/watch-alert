# ── Scheduler ──────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15

# ── State ──────────────────────────────────────────────────────────────────
# Directory where per-site state files are stored (default: current dir)
# Files are named  state_{site_key}.json  e.g. state_windvintage.json
STATE_DIR=.

# Override path for a specific site (optional):
# STATE_FILE_WINDVINTAGE=./data/windvintage.json

# ── Wind Vintage site options ───────────────────────────────────────────────
# Include Kith x Wind Vintage / Mr Porter partner listings (default: true)
INCLUDE_PARTNER_LISTINGS=true
